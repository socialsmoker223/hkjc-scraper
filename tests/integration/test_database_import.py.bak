"""Integration tests for SQLite database export functionality.

These tests verify:
- Database creation with correct schema
- Foreign key constraints
- Data import from JSON files
- Index creation
- Edge cases (empty data, duplicates, NULL foreign keys)
"""

import json
import sqlite3
from pathlib import Path

import pytest

# Import from main repo source
import sys
sys.path.insert(0, str(Path(__file__).parent.parent.parent.parent / "src"))

from hkjc_scraper.database import (
    _insert_dividend,
    _insert_horse,
    _insert_incident,
    _insert_jockey,
    _insert_performance,
    _insert_race,
    _insert_sectional_time,
    _insert_trainer,
    create_database,
    export_json_to_db,
)


@pytest.fixture
def temp_db_path(tmp_path: Path) -> Path:
    """Create a temporary database path.

    Args:
        tmp_path: Pytest temporary path fixture

    Returns:
        Path to temporary database file
    """
    return tmp_path / "test_hkjc.db"


@pytest.fixture
def temp_json_dir(tmp_path: Path) -> Path:
    """Create a temporary directory for JSON test data.

    Args:
        tmp_path: Pytest temporary path fixture

    Returns:
        Path to temporary JSON directory
    """
    json_dir = tmp_path / "json_data"
    json_dir.mkdir()
    return json_dir


